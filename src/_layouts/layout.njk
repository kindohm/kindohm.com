<!DOCTYPE html>
<html>
  <head>
    <title>{{ title }}</title>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <meta name="keywords" content="kindohm hodnick livecoding live-coding algorave code programming music electronic improvisation art audio computer computers tidalcycles synthesizer modular harmor synthesis minneapolis minnesota"/>
    <meta name="description" content="Mike Hodnick a.k.a. Kindohm. Programmer and sound artist."/>
    <link rel="stylesheet" href="/css/style3.css?v=aaxxxx">

    <style>
      :root {
        --ink: {{ metadata.theme.foreground }};
        --paper: {{ metadata.theme.background }};
        --muted: {{ metadata.theme.muted }};
        --bar: {{ metadata.theme.bar }};
        --link: {{ metadata.theme.link }};
        --signal: {{ metadata.theme.signal }};
        --hot: {{ metadata.theme.hot }};
        --cool: {{ metadata.theme.cool }};
      }
    </style>
  </head>
  <body>
    <div class="inner">
      {% include 'header.njk' %}

      <main>
        {{ content | safe }}
      </main>

      <footer>
    © Copyright 2026 Mike Hodnick. Unauthorized duplication may result in {{ metadata.risks | random }}. 
    </footer>
    </div>
  </body>
</html>
